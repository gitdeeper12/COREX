# COREX Environment Variables
# Causal Origin Resolution and Empirical eXamination

# ============= Statistical Stability Module =============
COREX_STAT_N_FOLDS=10
COREX_STAT_KERNEL_BANDWIDTH=0.5
COREX_STAT_BINNING_METHOD=adaptive

# ============= Representation Invariance Module =============
COREX_REP_TRANSFORMATIONS=pca,autoencoder,noise,dropout
COREX_REP_NOISE_SNR=10.0
COREX_REP_DROPOUT_RATES=0.1,0.2,0.5

# ============= Domain Robustness Module =============
COREX_DOMAIN_N_ENVIRONMENTS=5
COREX_DOMAIN_CLUSTERING_METHOD=kmeans
COREX_DOMAIN_CV_THRESHOLD=0.15

# ============= Intervention Consistency Module =============
COREX_INT_METHOD=propensity_matching
COREX_INT_N_SYNTHETIC=1000
COREX_INT_MONOTONICITY_CHECK=true

# ============= COREX Score Weights =============
COREX_WEIGHT_S=0.25
COREX_WEIGHT_R=0.25
COREX_WEIGHT_I=0.30
COREX_WEIGHT_D=0.20

# ============= Decision Thresholds =============
COREX_THRESHOLD_CAUSAL=0.80
COREX_THRESHOLD_SPURIOUS_MIN=0.50
COREX_THRESHOLD_SPURIOUS_MAX=0.79

# ============= Learnable Layer (Optional) =============
COREX_LEARNABLE_ENABLED=false
COREX_MLP_HIDDEN_DIM=64
COREX_MLP_N_LAYERS=2

# ============= Logging =============
COREX_LOG_LEVEL=INFO
COREX_SAVE_REPORT=true
COREX_REPORT_DIR=./reports

# ============= API Keys (Optional) =============
# GITHUB_TOKEN=your_token_here
# GITLAB_TOKEN=your_token_here
# PYPI_TOKEN=your_pypi_token_here
